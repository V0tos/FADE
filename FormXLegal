    --text:#F5F5F7; --muted:#8A8A93; --lime:#C6FF3D; --red:#FF2E3A;
  }
  *{box-sizing:border-box}
  html,body{margin:0;background:var(--bg);color:var(--text);
    font-family:-apple-system,BlinkMacSystemFont,"Inter","SF Pro Display",system-ui,sans-serif;
    -webkit-font-smoothing:antialiased}
  a{color:var(--lime);text-decoration:none}
  a:hover{text-decoration:underline}
  .wrap{max-width:860px;margin:0 auto;padding:48px 24px}
  nav{display:flex;justify-content:space-between;align-items:center;
    padding:20px 24px;border-bottom:1px solid var(--line);position:sticky;top:0;
    background:rgba(10,10,11,.85);backdrop-filter:blur(12px);z-index:10}
  nav .brand{font-weight:800;letter-spacing:.12em;text-transform:uppercase}
  nav .brand span{color:var(--lime)}
  nav ul{display:flex;gap:22px;list-style:none;margin:0;padding:0}
  nav ul a{color:var(--muted);font-size:14px;text-transform:uppercase;letter-spacing:.1em}
  nav ul a:hover{color:var(--text);text-decoration:none}
  .hero{padding:96px 24px 72px;text-align:center;border-bottom:1px solid var(--line)}
  .hero h1{font-size:clamp(40px,7vw,72px);margin:0 0 16px;line-height:1.02;letter-spacing:-.02em;font-weight:800}
  .hero h1 em{font-style:normal;color:var(--lime)}
  .hero p{color:var(--muted);font-size:18px;max-width:560px;margin:0 auto 32px}
  .cta{display:inline-block;background:var(--lime);color:#0A0A0B;padding:14px 24px;
    border-radius:8px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;font-size:14px}
  .cta:hover{text-decoration:none;transform:translateY(-1px);transition:transform .15s}
  .features{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
    gap:16px;padding:56px 24px;max-width:1000px;margin:0 auto}
  .card{background:var(--surface);border:1px solid var(--line);border-radius:12px;padding:22px}
  .card h3{margin:0 0 8px;font-size:16px;text-transform:uppercase;letter-spacing:.08em}
  .card p{margin:0;color:var(--muted);font-size:14px;line-height:1.5}
  .doc{border-top:1px solid var(--line);padding-top:40px;margin-top:40px}
  .doc h2{font-size:32px;letter-spacing:-.01em;margin:0 0 6px}
  .doc .updated{color:var(--muted);font-size:13px;margin-bottom:28px}
  .doc h3{margin-top:28px;font-size:17px;letter-spacing:.02em}
  .doc p,.doc li{color:#D4D4DA;line-height:1.65;font-size:15px}
  .doc ul{padding-left:20px}
  footer{border-top:1px solid var(--line);padding:32px 24px;text-align:center;color:var(--muted);font-size:13px;margin-top:64px}
  footer a{color:var(--muted)}
  hr{border:0;border-top:1px solid var(--line);margin:48px 0}
</style>
</head>
